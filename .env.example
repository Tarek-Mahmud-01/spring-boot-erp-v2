# Copy to .env and adjust as needed. Project-local only — never committed.

# --- Postgres (docker-compose maps host 55432 -> container 5432) ---
POSTGRES_DB=guru_erp
POSTGRES_USER=guru
POSTGRES_PASSWORD=guru

# --- Backend datasource (points at the docker Postgres on 55432) ---
DB_URL=jdbc:postgresql://localhost:55432/guru_erp
DB_USER=guru
DB_PASSWORD=guru

# --- Redis (docker-compose maps host 56379 -> container 6379) ---
REDIS_HOST=localhost
REDIS_PORT=56379

# --- JWT (dev secret; override in real environments). Base64 or raw >= 32 bytes. ---
JWT_SECRET=dev-only-change-me-32-bytes-minimum-secret-key
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# --- Server ---
SERVER_PORT=58080
